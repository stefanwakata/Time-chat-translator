# Supabase (required for frontend + backend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Backend API URL (used by the frontend to call the translation proxy)
VITE_API_URL=http://localhost:3001

# Supabase service role key (backend only — never expose to frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Docker / production
ALLOWED_ORIGINS=http://localhost:8080,https://your-azure-app.azurestaticapps.net
